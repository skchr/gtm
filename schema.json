{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "gtm Configuration",
  "description": "Configuration schema for gtm — a TUI music player",
  "type": "object",
  "properties": {
    "theme": {
      "description": "Theme seed for procedural color generation. Any string is valid; common presets: mocha, macchiato, frappe, latte, gruvbox-dark, gruvbox-light, dracula, tokyo-night, tokyo-night-storm, ayu-dark, ayu-light, random",
      "type": "string",
      "default": "mocha"
    },
    "refresh_theme": {
      "description": "Generate new colors on each launch from a fresh random seed (ignored unless theme='random' or true)",
      "type": "boolean",
      "default": false
    },
    "volume": {
      "description": "Initial volume level (0-100)",
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "default": 80
    },
    "last_tab": {
      "description": "Last active tab on quit (1=NowPlaying, 2=Library, 3=Settings)",
      "type": "integer",
      "minimum": 1,
      "maximum": 3,
      "default": 1
    },
    "idle_timeout": {
      "description": "Seconds of idle playback before daemon auto-exits",
      "type": "integer",
      "minimum": 30,
      "maximum": 3600,
      "default": 300
    },
    "ipc_timeout": {
      "description": "Seconds before IPC command times out",
      "type": "integer",
      "minimum": 1,
      "maximum": 30,
      "default": 3
    },
    "footer_preset": {
      "description": "Footer status bar preset",
      "type": "string",
      "enum": ["minimal", "compact", "full", "info", "navigator", "debug", "music", "clock"],
      "default": "compact"
    },
    "crossfade_duration": {
      "description": "Crossfade transition duration in seconds",
      "type": "integer",
      "minimum": 0,
      "maximum": 10,
      "default": 5
    },
    "crossfade_curve": {
      "description": "Crossfade curve type",
      "type": "string",
      "enum": ["equalPower", "quadratic", "cubic", "asymmetric"],
      "default": "quadratic"
    },
    "yt_cookie_source": {
      "description": "Browser cookie source for YouTube authentication",
      "type": "string",
      "default": ""
    },
    "yt_js_runtime": {
      "description": "JavaScript runtime for yt-dlp (node, bun, deno)",
      "type": "string",
      "enum": ["node", "bun", "deno"],
      "default": "node"
    },
    "yt_search_page_size": {
      "description": "Number of YouTube search results per page",
      "type": "integer",
      "minimum": 10,
      "maximum": 100,
      "default": 10
    },
    "yt_max_concurrent_downloads": {
      "description": "Maximum concurrent YouTube downloads",
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "default": 4
    },
    "yt_batch_download_mode": {
      "description": "Enable batch download mode for YouTube",
      "type": "boolean",
      "default": false
    },
    "visualizer": {
      "type": "object",
      "description": "Visualizer settings",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "bar_count": {
          "type": "integer",
          "minimum": 4,
          "maximum": 64,
          "default": 32
        }
      },
      "additionalProperties": false
    },
    "keybindings": {
      "type": "object",
      "description": "Custom keybinding overrides",
      "patternProperties": {
        "^[A-Za-z0-9_]+$": {
          "type": "string",
          "description": "Command ID to bind"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
