#!/bin/sh
# Pre-push hook: regenerate manpages from source and commit if changed.
set -e

echo "  [hook] regenerating manpages from source..."
nim r --path:src tools/genman.nim 2>&1

if ! git diff --quiet docs/gtm.1.md docs/gtmd.1.md; then
  echo "  [hook] manpages changed, committing..."
  git add docs/gtm.1.md docs/gtmd.1.md
  git commit -m "docs: sync manpage from source definitions"
  echo "  [hook] done"
else
  echo "  [hooks] no manpage changes"
fi
